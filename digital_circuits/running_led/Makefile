# ============================================================================
# 1. 基础项目配置区
# ============================================================================

# 定义 Verilog 的顶层模块名称，通常是 top
TOPNAME = top

# 指定 NVBoard 的引脚物理约束文件路径（用于连接 Verilog 信号和虚拟开发板引脚）
NXDC_FILES = constr/top.nxdc

# C/C++ 额外的头文件包含路径，当前为空。'?=' 表示如果环境变量中没定义则采用此值
INC_PATH ?=

# ============================================================================
# 2. Verilator 编译参数配置区
# ============================================================================

# 指定所使用的 Verilator 可执行文件命令
VERILATOR = verilator

# Verilator 核心编译参数：
# -MMD: 生成依赖关系文件
# --build: 自动调用底层的 C++ 编译器进行构建
# -cc: 将 Verilog 翻译成 C++ 代码
VERILATOR_CFLAGS += -MMD --build -cc  \
				-O3 --x-assign fast --x-initial fast --noassert
# 优化参数说明：
# -O3: 开启最高级别 C++ 优化，让仿真跑得最快
# --x-assign fast & --x-initial fast: 遇到未初始化的 x 状态时快速赋确定值，加速仿真
# --noassert: 关闭代码中的断言检查，提升极致运行速度

# ============================================================================
# 3. 目录与路径规划区
# ============================================================================

# 定义统一的构建输出目录，防止编译生成的垃圾文件弄脏源码区
BUILD_DIR = ./build

# Verilator 自动生成的中间 C++ 代码存放目录
OBJ_DIR = $(BUILD_DIR)/obj_dir

# 最终生成的可执行仿真文件（二进制文件）的完整路径
BIN = $(BUILD_DIR)/$(TOPNAME)

# 默认构建目标，输入 'make' 时会自动寻找 $(BIN) 规则来生成可执行文件
default: $(BIN)

# 在 Makefile 解析阶段，立刻调用 shell 命令创建 build 文件夹（如果不存在的话）
$(shell mkdir -p $(BUILD_DIR))

# ============================================================================
# 4. NVBoard 引脚自动绑定黑魔法
# ============================================================================

# 指定由 Python 脚本自动生成的 C++ 引脚绑定代码的具体绝对路径
SRC_AUTO_BIND = $(abspath $(BUILD_DIR)/auto_bind.cpp)

# 规则：如何生成引脚绑定代码。依赖于约束文件(.nxdc)
$(SRC_AUTO_BIND): $(NXDC_FILES)
	python3 $(NVBOARD_HOME)/scripts/auto_pin_bind.py $^ $@
# 执行 NVBoard 官方脚本，将约束文件($^)作为输入，转换为 C++ 绑定代码($@)作为输出

# ============================================================================
# 5. 源代码自动搜刮区
# ============================================================================

# 自动递归搜索 vsrc 目录下所有的 .v (Verilog) 源代码文件
VSRCS = $(shell find $(abspath ./vsrc) -name "*.v")

# 自动递归搜索 csrc 目录下所有的 C/C++ 测试平台源文件
CSRCS = $(shell find $(abspath ./csrc) -name "*.c" -or -name "*.cc" -or -name "*.cpp")

# 将刚才自动生成的引脚绑定 C++ 文件也加入到 C++ 源文件列表中，准备一起编译
CSRCS += $(SRC_AUTO_BIND)

# ============================================================================
# 6. 核心编译与链接规则
# ============================================================================

# 导入 NVBoard 官方预设的 Makefile 规则（会引入画图用的 SDL2 库路径和依赖）
include $(NVBOARD_HOME)/scripts/nvboard.mk

# 给额外的头文件路径加上 '-I' 前缀，符合 GCC 编译规范
INCFLAGS = $(addprefix -I, $(INC_PATH))

# 拼接 C++ 编译选项，并通过宏定义 (-D) 将顶层模块名传递给底层的 C++ 代码
CXXFLAGS += $(INCFLAGS) -DTOP_NAME="\"V$(TOPNAME)\""

# 终极编译规则：可执行文件依赖于 Verilog源码、C++源码 和 NVBoard静态库
$(BIN): $(VSRCS) $(CSRCS) $(NVBOARD_ARCHIVE)
	@rm -rf $(OBJ_DIR)
# 每次编译前先静默删除旧的中间文件夹，防止旧缓存导致奇葩的连接错误
	$(VERILATOR) $(VERILATOR_CFLAGS) \
		--top-module $(TOPNAME) $^ \
		$(addprefix -CFLAGS , $(CXXFLAGS)) $(addprefix -LDFLAGS , $(LDFLAGS)) \
		--Mdir $(OBJ_DIR) --exe -o $(abspath $(BIN))
# 调用 Verilator 执行完整的翻译、编译和链接过程：
# --top-module 指定顶层；$^ 代表传入上方定义的所有依赖文件；
# -CFLAGS 和 -LDFLAGS 负责把 C++ 编译参数和 SDL2 渲染库精准传给底层 GCC 编译器；
# --Mdir 和 -o 分别指定中间件和最终可执行文件的输出位置。

# ============================================================================
# 7. 日常操作快捷命令
# ============================================================================

# 提供 'make all' 目标，等同于 'make default'
all: default

# 'make run' 目标：先确保可执行文件已经生成，然后执行它
run: $(BIN)
	@$^
# @$^ 表示静默执行上方生成好的二进制仿真程序（执行后会弹出 NVBoard 虚拟开发板界面）

# 'make clean' 目标：一键删除整个 build 文件夹，彻底清理所有编译产物
clean:
	rm -rf $(BUILD_DIR)

# 声明这些目标是“伪目标”，它们不是真实存在的文件名，防止与同名文件冲突导致指令失效
.PHONY: default all clean run
